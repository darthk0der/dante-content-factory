# Anthropic — server-side only, never expose to client
ANTHROPIC_API_KEY=

# Framer — add once freelancer confirms CMS collection is live
FRAMER_API_KEY=
FRAMER_PROJECT_URL=

# Upstash Redis — auto-injected when you connect Upstash from Vercel Storage tab
# For local dev: copy from Vercel dashboard -> Storage -> Upstash -> .env.local
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=